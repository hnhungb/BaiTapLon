<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.MainController">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #FBE4FF; -fx-padding: 10 16;">
         <ImageView fitHeight="52.0" fitWidth="53.0" pickOnBounds="true" preserveRatio="true">
            <image>
               <Image url="@logo.png" />
            </image>
         </ImageView>
            <Text style="-fx-fill:black; -fx-font-size:16; -fx-font-weight:bold;" text=" Đấu Giá Trực Tuyến" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefresh" prefHeight="33.0" prefWidth="75.0" style="-fx-background-color: #6EB5FF; -fx-text-fill: black;" text="Làm mới">
            <font>
               <Font size="13.0" />
            </font></Button>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">

            <!-- ── TAB 1: Danh sách phiên đấu giá ── -->
            <Tab text="📋 Danh sách phiên">
                <VBox spacing="8" style="-fx-padding:12;">
                    <Label style="-fx-text-fill:#666; -fx-font-size:11;" text="Double-click vào một phiên để xem và đặt giá" />
                    <TableView fx:id="table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colTen" prefWidth="150" text="Sản phẩm" />
                            <TableColumn fx:id="colLoai" prefWidth="100" text="Loại" />
                            <TableColumn fx:id="colGia" prefWidth="110" text="Giá hiện tại" />
                            <TableColumn fx:id="colTrangThai" prefWidth="90" text="Trạng thái" />
                            <TableColumn fx:id="colKetThuc" prefWidth="155" text="Kết thúc" />
                            <TableColumn fx:id="colId" prefWidth="100" text="Mã phiên" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ── TAB 2: Đặt giá ── -->
            <Tab fx:id="tabBid" text="💰 Đặt giá">
                <SplitPane dividerPositions="0.55">

                    <!-- Bên trái: thông tin + điều khiển -->
                    <VBox spacing="10" style="-fx-padding:16;">
                        <Label fx:id="lblTenSanPham" style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#1565C0;" text="Chọn một phiên để xem" />
                        <HBox spacing="30">
                            <VBox>
                                <Label style="-fx-text-fill:#888; -fx-font-size:11;" text="Giá hiện tại" />
                                <Label fx:id="lblGiaHienTai" style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#E53935;" text="0 VNĐ" />
                            </VBox>
                            <VBox>
                                <Label style="-fx-text-fill:#888; -fx-font-size:11;" text="Người dẫn đầu" />
                                <Label fx:id="lblNguoiDanDau" text="-" />
                            </VBox>
                        </HBox>
                        <Label fx:id="lblTrangThai" style="-fx-text-fill:#555;" text="Trạng thái: -" />
                        <Label fx:id="lblKetThuc" style="-fx-text-fill:#555;" text="Kết thúc: -" />

                        <Separator />

                        <!-- Đặt giá thủ công -->
                        <Label style="-fx-font-weight:bold;" text="Đặt giá thủ công" />
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <TextField fx:id="tfSoTien" prefWidth="160" promptText="Số tiền (VNĐ)" />
                            <Button onAction="#handleDatGia" style="-fx-background-color: #FF9AA2; -fx-text-fill: white; -fx-font-weight: bold;" text="Đặt giá" />
                        </HBox>

                        <Separator />

                        <!-- Auto-bid -->
                        <Label style="-fx-font-weight:bold;" text="Đặt giá tự động (Auto-bid)" />
                        <HBox spacing="8">
                            <TextField fx:id="tfMaxBid" prefWidth="130" promptText="Tối đa (VNĐ)" />
                            <TextField fx:id="tfBuocGia" prefWidth="100" promptText="Bước tăng" />
                            <Button onAction="#handleAutoBid" style="-fx-background-color: #D5AAFF; -fx-text-fill: black;" text="Đăng ký" />
                        </HBox>

                        <Label fx:id="lblBidStatus" wrapText="true" />

                        <Separator />
                        <Label style="-fx-font-weight:bold;" text="Lịch sử đặt giá" />
                        <ListView fx:id="listHistory" style="-fx-font-family:monospace;" VBox.vgrow="ALWAYS" />
                    </VBox>

<!--                    &lt;!&ndash; Bên phải: biểu đồ giá &ndash;&gt;-->
<!--                    <VBox spacing="6" style="-fx-padding:12;">-->
<!--                        <Label style="-fx-font-weight:bold;" text="📈 Biểu đồ giá theo thời gian" />-->
<!--                        <LineChart fx:id="priceChart" VBox.vgrow="ALWAYS">-->
<!--                            <xAxis><NumberAxis label="Lần đặt" fx:id="xAxisChart" /></xAxis>-->
<!--                            <yAxis><NumberAxis fx:id="yAxisChart" label="Giá (VNĐ)" /></yAxis>-->
<!--                        </LineChart>-->
<!--                    </VBox>-->

                </SplitPane>
            </Tab>

            <!-- ── TAB 3: Đăng bán (ẩn với Bidder) ── -->
            <Tab fx:id="tabSell" text="🛒 Đăng bán">
                <VBox maxWidth="480" spacing="12" style="-fx-padding:24;">
                    <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1565C0;" text="Đăng sản phẩm mới để đấu giá">
                  <font>
                     <Font size="18.0" />
                  </font></Label>

                    <Label text="Tên sản phẩm:">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <TextField fx:id="tfItemName" promptText="Ví dụ: iPhone 15 Pro" />

                    <Label text="Loại sản phẩm:">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <ComboBox fx:id="cbItemType" maxWidth="Infinity" />

                    <Label text="Mô tả:">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <TextArea fx:id="taItemDesc" prefRowCount="3" promptText="Mô tả sản phẩm..." />

                    <HBox spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Giá khởi điểm (VNĐ):" />
                            <TextField fx:id="tfStartPrice" promptText="Ví dụ: 500000" />
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Thời gian (phút):" />
                            <TextField fx:id="tfDuration" promptText="Ví dụ: 60" />
                        </VBox>
                    </HBox>

                    <Button maxWidth="Infinity" onAction="#handleDangBan" style="-fx-background-color: #EFB0C9; -fx-text-fill: BLACK; -fx-font-size: 14; -fx-padding: 10;" text="🚀 Đăng bán">
                  <font>
                     <Font size="14.0" />
                  </font></Button>
                    <Label fx:id="lblSellStatus" wrapText="true" />
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
