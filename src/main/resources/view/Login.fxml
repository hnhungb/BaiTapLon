<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
    SỬA LỖI: bỏ TabPane vì 2 tab dùng chung fx:id gây xung đột.
    Thay bằng 1 form duy nhất, dùng StackPane để chuyển đổi giữa Login/Register.
-->

<StackPane style="-fx-background-color:#f0f4f8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.LoginController">

    <!-- PANEL ĐĂNG NHẬP -->
    <VBox fx:id="panelLogin" alignment="CENTER" maxWidth="534.0" prefHeight="480.0" prefWidth="480.0" spacing="14" style="-fx-padding: 40; -fx-background-color: #F3FFE3; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian,#ccc,10,0,0,2);">
        <HBox prefHeight="100.0" prefWidth="200.0">
            <children>
                <ImageView fitHeight="60.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@logo.png" />
                    </image>
                    <cursor>
                        <Cursor fx:constant="DEFAULT" />
                    </cursor>
                </ImageView>
                <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="50.0" prefWidth="357.0" text=" Hệ thống Đấu Giá Trực Tuyến" textAlignment="CENTER">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
            </children>
        </HBox>
        <Text style="-fx-font-size: 14; -fx-fill: #888;" text="Đăng nhập vào tài khoản">
         <font>
            <Font size="14.0" />
         </font></Text>

        <Label style="-fx-font-weight:bold;" text="Tên đăng nhập:">
         <font>
            <Font size="14.0" />
         </font></Label>
        <TextField fx:id="usernameField" maxWidth="300.0" minHeight="45.0" prefWidth="300.0" promptText="Nhập username" />

        <Label style="-fx-font-weight:bold;" text="Mật khẩu:">
         <font>
            <Font size="14.0" />
         </font></Label>
        <PasswordField fx:id="passwordField" maxWidth="300.0" minHeight="45.0" prefWidth="300.0" promptText="Nhập mật khẩu" />

        <Button alignment="CENTER" contentDisplay="CENTER" minHeight="45.0" mnemonicParsing="false" onAction="#handleLogin" prefHeight="46.0" prefWidth="146.0" style="-fx-background-color: #FFBEBC; -fx-text-fill: black; -fx-background-radius: 25; -fx-font-weight: bold; -fx-border-color: black; -fx-border-radius: 25;" text="Đăng nhập" />

        <Label fx:id="statusLabel" wrapText="true" />

        <Separator />
        <Label style="-fx-text-fill: #888; -fx-font-size: 13;" text="Chưa có tài khoản?">
         <font>
            <Font size="14.0" />
         </font></Label>
        <Button maxWidth="Infinity" onAction="#showRegister" style="-fx-background-color: #f5f5f5; -fx-font-size: 14;" text="Tạo tài khoản mới">
         <font>
            <Font size="14.0" />
         </font></Button>
    </VBox>

    <!-- PANEL ĐĂNG KÝ (ẩn mặc định) -->
    <VBox fx:id="panelRegister" alignment="CENTER" managed="false" maxWidth="360" spacing="14" style="-fx-padding:40; -fx-max-width:360; -fx-background-color:white;                  -fx-background-radius:8; -fx-effect:dropshadow(gaussian,#ccc,10,0,0,2);" visible="false">

        <Text style="-fx-font-size:18; -fx-font-weight:bold;" text="🏷 Hệ thống Đấu Giá" />
        <Text style="-fx-font-size:12; -fx-fill:#888;" text="Tạo tài khoản mới" />

        <Label style="-fx-font-weight:bold;" text="Tên đăng nhập:" />
        <TextField fx:id="regUsernameField" promptText="Chọn username" />

        <Label style="-fx-font-weight:bold;" text="Mật khẩu (ít nhất 6 ký tự):" />
        <PasswordField fx:id="regPasswordField" promptText="Chọn mật khẩu" />

        <Label style="-fx-font-weight:bold;" text="Loại tài khoản:" />
        <ComboBox fx:id="roleCombo" maxWidth="Infinity" />

        <Button maxWidth="Infinity" onAction="#handleRegister" style="-fx-background-color:#4CAF50; -fx-text-fill:white;                        -fx-font-size:13; -fx-padding:8; -fx-background-radius:4;" text="Đăng ký" />

        <Label fx:id="regStatusLabel" wrapText="true" />

        <Separator />
        <Button maxWidth="Infinity" onAction="#showLogin" style="-fx-background-color:#f5f5f5; -fx-font-size:12;" text="← Quay lại đăng nhập" />
    </VBox>

</StackPane>
