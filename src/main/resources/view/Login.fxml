<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
    SỬA LỖI: bỏ TabPane vì 2 tab dùng chung fx:id gây xung đột.
    Thay bằng 1 form duy nhất, dùng StackPane để chuyển đổi giữa Login/Register.
-->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="client.LoginController"
           style="-fx-background-color:#f0f4f8;">

    <!-- PANEL ĐĂNG NHẬP -->
    <VBox fx:id="panelLogin" spacing="14"
          style="-fx-padding:40; -fx-max-width:360; -fx-background-color:white;
                 -fx-background-radius:8; -fx-effect:dropshadow(gaussian,#ccc,10,0,0,2);"
          alignment="CENTER" maxWidth="360">

        <Text text="🏷 Hệ thống Đấu Giá"
              style="-fx-font-size:18; -fx-font-weight:bold;"/>
        <Text text="Đăng nhập vào tài khoản"
              style="-fx-font-size:12; -fx-fill:#888;"/>

        <Label text="Tên đăng nhập:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="usernameField" promptText="Nhập username"/>

        <Label text="Mật khẩu:" style="-fx-font-weight:bold;"/>
        <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu"/>

        <Button text="Đăng nhập" onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color:#2196F3; -fx-text-fill:white;
                       -fx-font-size:13; -fx-padding:8; -fx-background-radius:4;"/>

        <Label fx:id="statusLabel" wrapText="true"/>

        <Separator/>
        <Label text="Chưa có tài khoản?"
               style="-fx-text-fill:#888; -fx-font-size:11;"/>
        <Button text="Tạo tài khoản mới" onAction="#showRegister"
                maxWidth="Infinity"
                style="-fx-background-color:#f5f5f5; -fx-font-size:12;"/>
    </VBox>

    <!-- PANEL ĐĂNG KÝ (ẩn mặc định) -->
    <VBox fx:id="panelRegister" spacing="14" visible="false" managed="false"
          style="-fx-padding:40; -fx-max-width:360; -fx-background-color:white;
                 -fx-background-radius:8; -fx-effect:dropshadow(gaussian,#ccc,10,0,0,2);"
          alignment="CENTER" maxWidth="360">

        <Text text="🏷 Hệ thống Đấu Giá"
              style="-fx-font-size:18; -fx-font-weight:bold;"/>
        <Text text="Tạo tài khoản mới"
              style="-fx-font-size:12; -fx-fill:#888;"/>

        <Label text="Tên đăng nhập:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="regUsernameField" promptText="Chọn username"/>

        <Label text="Mật khẩu (ít nhất 6 ký tự):" style="-fx-font-weight:bold;"/>
        <PasswordField fx:id="regPasswordField" promptText="Chọn mật khẩu"/>

        <Label text="Loại tài khoản:" style="-fx-font-weight:bold;"/>
        <ComboBox fx:id="roleCombo" maxWidth="Infinity"/>

        <Button text="Đăng ký" onAction="#handleRegister"
                maxWidth="Infinity"
                style="-fx-background-color:#4CAF50; -fx-text-fill:white;
                       -fx-font-size:13; -fx-padding:8; -fx-background-radius:4;"/>

        <Label fx:id="regStatusLabel" wrapText="true"/>

        <Separator/>
        <Button text="← Quay lại đăng nhập" onAction="#showLogin"
                maxWidth="Infinity"
                style="-fx-background-color:#f5f5f5; -fx-font-size:12;"/>
    </VBox>

</StackPane>
