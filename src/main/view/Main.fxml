<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.MainController"
            style="-fx-background-color:#1a1a2e;">

    <!-- TOP BAR -->
    <top>
        <HBox style="-fx-background-color:#16213e; -fx-padding:12 20;" spacing="16" alignment="CENTER_LEFT">
            <Text text="🏷 Online Auction"
                  style="-fx-font-size:18; -fx-fill:#e94560; -fx-font-weight:bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⟳ Refresh" onAction="#handleRefresh"
                    style="-fx-background-color:#0f3460; -fx-text-fill:white; -fx-background-radius:4;"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color:#1a1a2e;">

            <!-- ── TAB 1: AUCTION LIST ── -->
            <Tab text="📋 Auctions">
                <VBox style="-fx-padding:16;" spacing="10">
                    <Label text="Double-click an auction to bid"
                           style="-fx-text-fill:#a8a8b3; -fx-font-size:11;"/>
                    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color:#16213e; -fx-border-color:#0f3460;">
                        <columns>
                            <TableColumn fx:id="colItem"         text="Item"          prefWidth="200"/>
                            <TableColumn fx:id="colCategory"     text="Category"      prefWidth="100"/>
                            <TableColumn fx:id="colCurrentPrice" text="Current Price" prefWidth="120"/>
                            <TableColumn fx:id="colStatus"       text="Status"        prefWidth="90"/>
                            <TableColumn fx:id="colEndTime"      text="Ends At"       prefWidth="160"/>
                            <TableColumn fx:id="colId"           text="ID"            prefWidth="260"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ── TAB 2: BID ── -->
            <Tab fx:id="tabBid" text="💰 Bid">
                <SplitPane dividerPositions="0.55"
                           style="-fx-background-color:#1a1a2e;">

                    <!-- LEFT: Bid controls -->
                    <VBox style="-fx-padding:20;" spacing="12">
                        <Label fx:id="lblAuctionTitle"
                               text="Select an auction"
                               style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#e94560;"/>
                        <HBox spacing="20">
                            <VBox spacing="4">
                                <Label text="Current Price" style="-fx-text-fill:#a8a8b3; -fx-font-size:11;"/>
                                <Label fx:id="lblCurrentPrice" text="0.00"
                                       style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#4ecca3;"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Leader" style="-fx-text-fill:#a8a8b3; -fx-font-size:11;"/>
                                <Label fx:id="lblLeader" text="-"
                                       style="-fx-font-size:14; -fx-text-fill:#e0e0e0;"/>
                            </VBox>
                        </HBox>
                        <Label fx:id="lblStatus"  text="Status: -" style="-fx-text-fill:#a8a8b3;"/>
                        <Label fx:id="lblEndTime" text="Ends: -"   style="-fx-text-fill:#a8a8b3;"/>

                        <Separator/>

                        <!-- Manual bid -->
                        <Label text="Manual Bid" style="-fx-text-fill:#e0e0e0; -fx-font-weight:bold;"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <TextField fx:id="bidAmountField" promptText="Amount ($)"
                                       prefWidth="140"
                                       style="-fx-background-color:#16213e; -fx-text-fill:white; -fx-border-color:#e94560; -fx-border-radius:4; -fx-background-radius:4;"/>
                            <Button text="Place Bid" onAction="#handlePlaceBid"
                                    style="-fx-background-color:#e94560; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:4;"/>
                        </HBox>

                        <Separator/>

                        <!-- Auto bid -->
                        <Label text="Auto-Bid" style="-fx-text-fill:#e0e0e0; -fx-font-weight:bold;"/>
                        <HBox spacing="8">
                            <TextField fx:id="autoMaxBidField" promptText="Max ($)"
                                       prefWidth="100"
                                       style="-fx-background-color:#16213e; -fx-text-fill:white; -fx-border-color:#0f3460; -fx-border-radius:4; -fx-background-radius:4;"/>
                            <TextField fx:id="autoIncrementField" promptText="Step ($)"
                                       prefWidth="100"
                                       style="-fx-background-color:#16213e; -fx-text-fill:white; -fx-border-color:#0f3460; -fx-border-radius:4; -fx-background-radius:4;"/>
                            <Button text="Register Auto-Bid" onAction="#handleRegisterAutoBid"
                                    style="-fx-background-color:#0f3460; -fx-text-fill:white; -fx-background-radius:4;"/>
                        </HBox>

                        <Label fx:id="bidStatusLabel" wrapText="true"
                               style="-fx-text-fill:green;"/>

                        <Separator/>
                        <Label text="Bid History" style="-fx-text-fill:#e0e0e0; -fx-font-weight:bold;"/>
                        <ListView fx:id="bidHistoryList" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color:#16213e; -fx-border-color:#0f3460; -fx-font-family:monospace;"/>
                    </VBox>

                </SplitPane>
            </Tab>

            <!-- ── TAB 3: SELLER (hidden for bidders) ── -->
            <Tab fx:id="tabSeller" text="🛒 Sell">
                <VBox style="-fx-padding:24;" spacing="14" maxWidth="500">
                    <Label text="List a New Item for Auction"
                           style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#e94560;"/>

                    <Label text="Item Name" style="-fx-text-fill:#e0e0e0;"/>
                    <TextField fx:id="itemNameField" promptText="e.g. iPhone 16 Pro"
                               style="-fx-background-color:#16213e; -fx-text-fill:white; -fx-border-color:#0f3460; -fx-border-radius:4; -fx-background-radius:4;"/>

                    <Label text="Category" style="-fx-text-fill:#e0e0e0;"/>
                    <ComboBox fx:id="itemCategoryCombo" maxWidth="Infinity"/>

                    <Label text="Description" style="-fx-text-fill:#e0e0e0;"/>
                    <TextArea fx:id="itemDescArea" promptText="Describe your item..."
                              prefRowCount="3"
                              style="-fx-background-color:#16213e; -fx-text-fill:white; -fx-border-color:#0f3460; -fx-border-radius:4; -fx-background-radius:4;"/>

                    <HBox spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Starting Price ($)" style="-fx-text-fill:#e0e0e0;"/>
                            <TextField fx:id="startPriceField" promptText="100"
                                       style="-fx-background-color:#16213e; -fx-text-fill:white; -fx-border-color:#0f3460; -fx-border-radius:4; -fx-background-radius:4;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Duration (minutes)" style="-fx-text-fill:#e0e0e0;"/>
                            <TextField fx:id="durationField" promptText="60"
                                       style="-fx-background-color:#16213e; -fx-text-fill:white; -fx-border-color:#0f3460; -fx-border-radius:4; -fx-background-radius:4;"/>
                        </VBox>
                    </HBox>

                    <Button text="🚀 Create Auction" onAction="#handleCreateAuction"
                            maxWidth="Infinity"
                            style="-fx-background-color:#e94560; -fx-text-fill:white; -fx-font-size:14; -fx-font-weight:bold; -fx-padding:12; -fx-background-radius:4;"/>
                    <Label fx:id="createStatusLabel" wrapText="true" style="-fx-text-fill:green;"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
